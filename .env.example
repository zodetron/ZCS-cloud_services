# ============================================================
# StorageCloud — Unified Environment Variables
# Copy this file to .env and fill in your values.
# This single file is used by: backend, frontend (Next.js), and docker-compose.
# ============================================================

# --- PostgreSQL ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=storagecloud

# Full connection string used by Prisma (local dev)
# In Docker, docker-compose overrides this to point at the postgres container.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/storagecloud

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- MinIO (S3-compatible object storage) ---
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_DEFAULT_BUCKET=storagecloud

# --- JWT Authentication ---
# Change BOTH secrets to long random strings before deploying to production.
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change-me-refresh-in-production
JWT_REFRESH_EXPIRES_IN=30d

# --- Backend Server ---
PORT=4000
NODE_ENV=development

# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:3000

# --- Frontend (Next.js) ---
# Must be the public-facing URL of the backend API.
# NEXT_PUBLIC_* vars are baked into the Next.js bundle at BUILD time.
# In Docker, this is passed as a build ARG — changing it requires a rebuild.
NEXT_PUBLIC_API_URL=http://localhost:4000
